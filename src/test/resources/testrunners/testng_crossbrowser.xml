<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Opencart App Test Regression Suit" verbose="4" thread-count="2" parallel="tests">
	<!-- Cross Browser Testing for LoginPageTest -->
	<test name = "Login Page Test_chrome">
		<parameter name="browser" value="chrome" />
		<classes>
			<class name="com.qa.opencart.tests.LoginPageTest"/>
		</classes>
	</test>
	
	<test name = "Login Page Test_firefox">
		<parameter name="browser" value="firefox" />
		<classes>
			<class name="com.qa.opencart.tests.LoginPageTest"/>
		</classes>
	</test>
	
	<test name = "Accounts Page Test">
		<parameter name="browser" value="firefox" />
		<classes>
			<class name="com.qa.opencart.tests.AccountsPageTest"/>
		</classes>
	</test>
	
	<test name = "Search Test">
		<parameter name="browser" value="chrome" />
		<classes>
			<class name="com.qa.opencart.tests.SearchTest"/>
		</classes>
	</test>
	
	<test name = "ProductInfo Page Test">
		<parameter name="browser" value="chrome" />
		<classes>
			<class name="com.qa.opencart.tests.ProductInfoPageTest"/>
		</classes>
	</test>
	
	<test name = "Register Page Test">
		<parameter name="browser" value="chrome" />
		<classes>
			<class name="com.qa.opencart.tests.RegisterPageTest"/>
		</classes>
	</test>
	
</suite> 